#!/bin/sh
set -eu

AUTH_FILE="${BABY_DAYBOOK_AUTH_FILE:-$HOME/.config/baby-daybook/auth.json}"

if [ ! -f "$AUTH_FILE" ]; then
  echo "Baby Daybook login not found at $AUTH_FILE" >&2
  echo "Log in with the baby-daybook CLI first." >&2
  exit 1
fi

if ! command -v node >/dev/null 2>&1; then
  echo "Node.js is required to read the Baby Daybook auth file safely." >&2
  exit 1
fi

if command -v pbcopy >/dev/null 2>&1; then
  CLIPBOARD_COMMAND="pbcopy"
elif command -v wl-copy >/dev/null 2>&1; then
  CLIPBOARD_COMMAND="wl-copy"
elif command -v xclip >/dev/null 2>&1; then
  CLIPBOARD_COMMAND="xclip -selection clipboard"
else
  echo "No supported clipboard command found (pbcopy, wl-copy, or xclip)." >&2
  exit 1
fi

node -e '
  const fs = require("fs");
  const auth = JSON.parse(fs.readFileSync(process.argv[1], "utf8"));
  if (typeof auth.refreshToken !== "string" || auth.refreshToken.length === 0) {
    throw new Error("The Baby Daybook auth file has no refresh token");
  }
  process.stdout.write(auth.refreshToken);
' "$AUTH_FILE" | sh -c "$CLIPBOARD_COMMAND"

echo "Baby Daybook refresh token copied to the clipboard (value not displayed)."
